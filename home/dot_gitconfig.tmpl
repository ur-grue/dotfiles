# NUR Identität. Die geteilten Einstellungen (Aliase, delta, pull.rebase …) liegen
# in ~/.config/git/config — Git liest beide Dateien. So kann `--existing` diese
# ~/.gitconfig auf einem bestehenden System komplett in Ruhe lassen (via
# .chezmoiignore), ohne dass die geteilte Config verloren geht.
#
# Leere Werte werden NIE geschrieben (sonst: „empty ident name not allowed").
{{- if or .name .email }}
[user]
{{- if .name }}
    name  = {{ .name }}
{{- end }}
{{- if .email }}
    email = {{ .email }}
{{- end }}
{{- end }}
